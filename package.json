    "test": "npx cypress run --browser chrome",
  "report:merge": "mochawesome-merge cypress/reports/mochawesome*.json > cypress/reports/final-report.json",
  "report:generate": "marge cypress/reports/final-report.json --reportDir cypress/reports --inline",
